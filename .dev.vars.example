# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit it.

# Non-secrets (keep in sync with wrangler.toml [vars])
PROPERTY_ID=refuge-sauvage-001
PROPERTY_NAME=Le Refuge Sauvage
OWNER_EMAIL=bonjour@refugesauvage.be
PRICE_PER_NIGHT=150
SITE_URL=http://localhost:8788
# In production (wrangler.toml): https://holiday-rental-template.pages.dev
# Use onboarding@resend.dev until client domain is verified with Resend
FROM_EMAIL=onboarding@resend.dev

# Airbnb iCal export URL — get from Airbnb › Listing › Availability › Export Calendar
ICAL_URL=

# Owner's bank account number (IBAN) — displayed in the payment email sent to guests
OWNER_IBAN=BE00 0000 0000 0000

# Secrets — production values go in secrets.json → npm run deploy:secrets
RESEND_API_KEY=re_...
APPROVE_SECRET=change-me-to-a-long-random-string
